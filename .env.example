# NVIDIA inference (required)
NVIDIA_API_KEY=nvapi-your-key-here

# Remote access (optional — set if accessing from another machine)
# Forward port 18789 first (Brev: "Share a Service", ngrok: ngrok http 18789)
# See BUILD.md § Remote Access for details
# CHAT_UI_URL=https://your-forwarded-url.example.com

# Telegram bot (optional — enables mobile access)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# ALLOWED_CHAT_IDS=your-chat-id-from-userinfobot

# Inference model (optional — defaults to upstream NemoClaw default)
# NEMOCLAW_MODEL=openai/gpt-oss-120b

# Search / tool integrations (optional)
# BRAVE_API_KEY=BSA-your-key-here
