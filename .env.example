# ──────────────────────────────────────────────────────────────────
# NVIDIA Inference (required)
# ──────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-key-here

# Inference provider (optional — defaults to NVIDIA cloud)
# Valid values: build (NVIDIA cloud), openai, anthropic, anthropicCompatible,
#               gemini, ollama, custom, nim-local, vllm
# NEMOCLAW_PROVIDER=build

# Inference model (optional — defaults to nvidia/nemotron-3-super-120b-a12b)
# Must match the provider. You can switch at runtime without rebuilding:
#   openshell inference set --provider nvidia-prod --model <model>
# NEMOCLAW_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Custom inference endpoint (optional — for custom/nim-local/vllm providers)
# NEMOCLAW_ENDPOINT_URL=http://localhost:8000/v1

# Alternative inference provider keys (optional — set with matching NEMOCLAW_PROVIDER)
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ──────────────────────────────────────────────────────────────────
# Messaging (optional)
# ──────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# TELEGRAM_ALLOWED_IDS=your-chat-id-from-userinfobot  # comma-separated; restricts who can DM the bot
# DISCORD_BOT_TOKEN=your-discord-bot-token
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ──────────────────────────────────────────────────────────────────
# Web Search (optional)
# ──────────────────────────────────────────────────────────────────
# Tavily (recommended) or Brave — uncomment one.
#   https://app.tavily.com/sign-in
# TAVILY_API_KEY=
# BRAVE_API_KEY=

# ──────────────────────────────────────────────────────────────────
# Sandbox Tools (optional — default: true)
# ──────────────────────────────────────────────────────────────────
# Set to false to exclude from the sandbox image
# INSTALL_CLAUDE_CODE=true
# INSTALL_CODEX=true

# ──────────────────────────────────────────────────────────────────
# Network Policy (optional)
# ──────────────────────────────────────────────────────────────────
# Upstream NemoClaw uses a tier-based selector. The cookbook's setup.sh
# derives a preset list from the credentials you've set above (adds
# telegram/discord/slack/brave when the matching token is configured).
# Override any of the below to take full control.
#
# Policy tier (restricted | balanced | open). Default: balanced.
#   restricted: inference + core tooling only
#   balanced:   + npm, pypi, huggingface, brew, brave
#   open:       + slack, discord, telegram, jira, outlook
# NEMOCLAW_POLICY_TIER=balanced

# Policy presets (comma-separated). Overrides tier defaults when set.
# Available: pypi, npm, telegram, discord, slack, brave, brew, docker, huggingface, jira, outlook
# NEMOCLAW_POLICY_PRESETS=pypi,npm,telegram,brave

# Policy mode (suggested | custom | skip). Default: suggested.
#   suggested: tier defaults, with NEMOCLAW_POLICY_PRESETS as override
#   custom:    only use NEMOCLAW_POLICY_PRESETS (required)
#   skip:      no policy presets applied
# NEMOCLAW_POLICY_MODE=suggested

# ──────────────────────────────────────────────────────────────────
# Advanced (optional)
# ──────────────────────────────────────────────────────────────────
# NEMOCLAW_SANDBOX_NAME=my-assistant
# NEMOCLAW_RECREATE_SANDBOX=1
# NEMOCLAW_GPU=a2-highgpu-1g:nvidia-tesla-a100:1
# ENABLE_TERMINAL_SERVER=true
# TUNNEL_FQDN=your-secure-link.brevlab.com

# OpenClaw version override (experimental — rebuilds sandbox-base locally)
# OPENCLAW_VERSION=
