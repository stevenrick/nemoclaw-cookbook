# NVIDIA inference (required)
NVIDIA_API_KEY=nvapi-your-key-here

# Inference provider (optional — defaults to NVIDIA cloud)
# Valid values: build (NVIDIA cloud), openai, anthropic, anthropicCompatible,
#               gemini, ollama, custom, nim-local, vllm
# NEMOCLAW_PROVIDER=build

# Inference model (optional — defaults to nvidia/nemotron-3-super-120b-a12b)
# Must match the provider. You can switch at runtime without rebuilding:
#   openshell inference set --provider nvidia-prod --model <model>
# NEMOCLAW_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Custom inference endpoint (optional — for custom/nim-local/vllm providers)
# NEMOCLAW_ENDPOINT_URL=http://localhost:8000/v1

# Telegram bot (optional — enables mobile access)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# ALLOWED_CHAT_IDS=your-chat-id-from-userinfobot

# Discord bot (optional — enables Discord access)
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack bot (optional — enables Slack access)
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Search / tool integrations (optional)
# BRAVE_API_KEY=BSA-your-key-here

# Sandbox tools (optional — default: true)
# Set to false to exclude from the sandbox image
# INSTALL_CLAUDE_CODE=true
# INSTALL_CODEX=true

# Alternative inference providers (optional — set with matching NEMOCLAW_PROVIDER)
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Policy presets (optional — comma-separated, defaults to pypi,npm)
# Auto-detects telegram,slack,discord when tokens are set.
# Available: pypi, npm, telegram, discord, slack, brave, docker, huggingface, jira, outlook
# NEMOCLAW_POLICY_PRESETS=pypi,npm,telegram,brave

# Policy mode (optional — defaults to suggested)
# suggested: auto-detect + NEMOCLAW_POLICY_PRESETS override
# custom: only use NEMOCLAW_POLICY_PRESETS (no auto-detect)
# skip: no policy presets applied
# NEMOCLAW_POLICY_MODE=suggested

# GPU for deploy command (optional — Brev instance type)
# NEMOCLAW_GPU=a2-highgpu-1g:nvidia-tesla-a100:1
